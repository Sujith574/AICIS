# AICIS Backend Environment Variables
# Copy this to .env and update for your environment.

# MongoDB configuration
# For local dev: mongodb://localhost:27017
# For persistence on Render, use MongoDB Atlas URI.
MONGO_URI=mongodb://localhost:27017
MONGO_DB=aicis_db

# Security
# Run 'openssl rand -hex 32' to generate a real secret key
SECRET_KEY=aicis-super-secret-jwt-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# paths (relative to backend/services/ or absolute)
# For Render, these are usually provided by the render.yaml blueprint
FACE_DATA_DIR=./face_data
MODEL_PATH=../../ml/model.pkl
SCALER_PATH=../../ml/scaler.pkl

# CORS - Add your frontend URLs here (comma-separated)
# e.g., http://localhost:5173,https://yourname.github.io
CORS_ORIGINS=http://localhost:5173
